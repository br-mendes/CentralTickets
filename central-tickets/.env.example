# Environment Variables for CentralTickets
# Copie este arquivo para .env.local e preencha os valores

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# GLPI PETA
GLPI_PETA_URL=https://glpi.petacorp.com.br/apirest.php
GLPI_PETA_USER_TOKEN=your-user-token
GLPI_PETA_APP_TOKEN=your-app-token
GLPI_PETA_TICKET_URL=https://glpi.petacorp.com.br/front/ticket.form.php?id=

# GLPI GMX
GLPI_GMX_URL=https://glpi.gmxtecnologia.com.br/apirest.php
GLPI_GMX_USER_TOKEN=your-user-token
GLPI_GMX_APP_TOKEN=your-app-token
GLPI_GMX_TICKET_URL=https://glpi.gmxtecnologia.com.br/front/ticket.form.php?id=
